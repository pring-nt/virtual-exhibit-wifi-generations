---
// src/components/exhibit/SummaryTable.astro
---
<div class="my-6 w-full overflow-hidden rounded-md border border-[var(--c-rule)] sm:overflow-x-auto">
    <table class="responsive-table !my-0 !border-0 w-full">
        <thead>
        <tr>
            <th>Standard</th>
            <th>Year</th>
            <th>Also Known As</th>
            <th>Frequency</th>
            <th>Max Throughput</th>
            <th>Key Technology</th>
        </tr>
        </thead>
        <tbody>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11b</td>
            <td data-label="Year">1999</td>
            <td data-label="Also Known As">Wi‑Fi 1</td>
            <td data-label="Frequency">2.4 GHz</td>
            <td data-label="Max Throughput">11 Mbps</td>
            <td data-label="Key Technology">CCK</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11a</td>
            <td data-label="Year">1999</td>
            <td data-label="Also Known As">—</td>
            <td data-label="Frequency">5 GHz</td>
            <td data-label="Max Throughput">54 Mbps</td>
            <td data-label="Key Technology">OFDM</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11g</td>
            <td data-label="Year">2003</td>
            <td data-label="Also Known As">—</td>
            <td data-label="Frequency">2.4 GHz</td>
            <td data-label="Max Throughput">54 Mbps</td>
            <td data-label="Key Technology">OFDM</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11n</td>
            <td data-label="Year">2009</td>
            <td data-label="Also Known As">Wi‑Fi 4</td>
            <td data-label="Frequency">2.4 + 5 GHz</td>
            <td data-label="Max Throughput">600 Mbps</td>
            <td data-label="Key Technology">MIMO</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11ac</td>
            <td data-label="Year">2013</td>
            <td data-label="Also Known As">Wi‑Fi 5</td>
            <td data-label="Frequency">5 GHz</td>
            <td data-label="Max Throughput">3.5 Gbps</td>
            <td data-label="Key Technology">MU‑MIMO</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11ax</td>
            <td data-label="Year">2020</td>
            <td data-label="Also Known As">Wi‑Fi 6 / 6E</td>
            <td data-label="Frequency">2.4 + 5 + 6 GHz</td>
            <td data-label="Max Throughput">9.6 Gbps</td>
            <td data-label="Key Technology">OFDMA</td>
        </tr>
        <tr>
            <td data-label="Standard" class="font-bold text-[var(--c-ink)]">802.11be</td>
            <td data-label="Year">Present</td>
            <td data-label="Also Known As">Wi‑Fi 7</td>
            <td data-label="Frequency">2.4 + 5 + 6 GHz</td>
            <td data-label="Max Throughput">46 Gbps</td>
            <td data-label="Key Technology">MLO</td>
        </tr>
        </tbody>
    </table>
</div>